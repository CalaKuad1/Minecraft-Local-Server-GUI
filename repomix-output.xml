                    {/* General Settings */}
                    <div className="bg-surface border border-white/5 p-6 rounded-2xl h-fit">
                        <h3 className="text-lg font-semibold text-white mb-4 flex items-center gap-2">
                            <FolderOpen size={20} className="text-primary" />
